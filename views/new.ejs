<%- layout('layout/boilerplate') -%>

<div class="page-header">
  <h1>New Request</h1>
  <a href="/requests" class="button secondary">← Back to Requests</a>
</div>

<%- include('partials/alert') %>

<form method="POST" action="/requests" class="form needs-validation" novalidate>
  <div class="mb-3">
    <label for="title" class="form-label">Title</label>
    <input
      type="text"
      id="title"
      name="title"
      class="form-control"
      required
      value="<%= locals.title || '' %>"
    >
    <div class="invalid-feedback">Please enter a request title.</div>
  </div>
  
  <div class="mb-3">
    <label for="description" class="form-label">Description</label>
    <textarea id="description" name="description" rows="5" class="form-control"><%= locals.description || '' %></textarea>
  </div>
  
  <div class="mb-3">
    <label for="userId" class="form-label">Assign to</label>
    <select id="userId" name="userId" class="form-select" required>
      <option value="">Select User</option>
      <% users.forEach(user => { %>
        <option value="<%= user.id %>" <%= locals.userId == user.id ? 'selected' : '' %>>
          <%= user.name %> (<%= user.role %>)
        </option>
      <% }) %>
    </select>
    <div class="invalid-feedback">Please select a user.</div>
  </div>
  
  <div class="form-actions">
    <button type="submit" class="button primary">Create Request</button>
    <a href="/requests" class="button secondary">Cancel</a>
  </div>
</form>
