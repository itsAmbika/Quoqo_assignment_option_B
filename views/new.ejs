<%- layout('layout/boilerplate') -%>

<div class="page-header">
  <h1>New Request</h1>
  <a href="/requests" class="button secondary">← Back to Requests</a>
</div>

<%- include('partials/alert') %>

<form method="POST" action="/requests" class="form">
  <div class="form-group">
    <label for="title">Title:</label>
    <input type="text" id="title" name="title" required value="<%= locals.title || '' %>">
  </div>
  
  <div class="form-group">
    <label for="description">Description:</label>
    <textarea id="description" name="description" rows="5"><%= locals.description || '' %></textarea>
  </div>
  
  <div class="form-group">
    <label for="userId">Assign to:</label>
    <select id="userId" name="userId" required>
      <option value="">Select User</option>
      <% users.forEach(user => { %>
        <option value="<%= user.id %>" <%= locals.userId == user.id ? 'selected' : '' %>>
          <%= user.name %> (<%= user.role %>)
        </option>
      <% }) %>
    </select>
  </div>
  
  <div class="form-actions">
    <button type="submit" class="button primary">Create Request</button>
    <a href="/requests" class="button secondary">Cancel</a>
  </div>
</form>

