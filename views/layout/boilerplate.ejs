<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container">
      <a class="navbar-brand" href="/requests">Workflow Requests</a>
      <ul class="navbar-nav ms-auto">
        <% if (typeof session !== 'undefined' && session && session.userId) { %>
          <li class="nav-item">
            <span class="nav-link">Hi, <%= session.userEmail %> (<%= session.userRole %>)</span>
          </li>
          <li class="nav-item">
            <form method="POST" action="/logout" style="display: inline;">
              <button type="submit" class="nav-link btn btn-outline-light btn-sm">Logout</button>
            </form>
          </li>
        <% } else { %>



          <li class="nav-item">
            <a class="nav-link" href="/login">Login</a>
          </li>
        <% } %>
      </ul>
    </div>
  </nav>
  <main class="container mt-4">
    <% if (typeof alerts !== 'undefined' && alerts && alerts.error && alerts.error.length > 0) { %>
      <%- include('../partials/alert') %>
    <% } %>
    <%- body %>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/script.js"></script>
</body>
</html>
