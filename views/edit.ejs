<% layout('layout/boilerplate') %>

<div class="page-header">
  <h1>Edit Request</h1>
  <a href="/requests" class="button secondary">Back to Requests</a>
</div>

<form method="POST" action="/requests/<%= request.id %>/edit" class="form">
  <label for="title">Title</label>
  <input type="text" id="title" name="title" value="<%= request.title %>" required>

  <label for="description">Description</label>
  <textarea id="description" name="description" rows="5"><%= request.description || '' %></textarea>

  <label for="status">Status</label>
  <select id="status" name="status" required>
    <% statuses.forEach((status) => { %>
      <option value="<%= status %>" <%= request.status === status ? 'selected' : '' %>>
        <%= status %>
      </option>
    <% }) %>
  </select>

  <label for="userId">Created By</label>
  <select id="userId" name="userId" required>
    <% users.forEach((user) => { %>
      <option value="<%= user.id %>" <%= request.userId === user.id ? 'selected' : '' %>>
        <%= user.name %> (<%= user.role %>)
      </option>
    <% }) %>
  </select>

  <button type="submit" class="button">Update Request</button>
</form>
